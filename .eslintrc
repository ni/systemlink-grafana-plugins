{
  "extends": "./.config/.eslintrc",
  "ignorePatterns": [
    "acceptance-tests/playwright-report/",
    "acceptance-tests/playwright-results/"
  ],
  "overrides": [
    {
      "files": ["**/*.test.ts", "**/*.test.tsx"],
      "plugins": ["jest"],
      "extends": ["plugin:jest/recommended"]
    },
    {
      "files": ["**/**.ts", "**/*.tsx"],
      "rules": {
        "no-console": ["error", { "allow": ["warn", "error"] }]
      }
    // },
    // {
    //   "files": ["acceptance-tests/**/*.ts", "acceptance-tests/**/*.js"],
    //   "rules": {
    //     "no-unused-vars": "off",
    //     "@typescript-eslint/no-unused-vars":"error"
    //   }
    }
  ]
}